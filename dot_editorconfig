# ~/.editorconfig — baseline formatting for projects that don't ship their own.
# Most editors honor this automatically; a few need a plugin. A project's own
# .editorconfig with `root = true` overrides this within that project.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,jsonc,yml,yaml,html,css,scss,vue,svelte}]
indent_size = 2

[*.go]
indent_style = tab

[{Makefile,*.mk}]
indent_style = tab

[*.md]
trim_trailing_whitespace = false   # two trailing spaces = an intentional break
