# Global gitignore — Linux, editor, and personal cruft that should never be
# committed in ANY repository. Project-specific build artifacts (node_modules,
# __pycache__, dist/) belong in each project's own .gitignore, not here.
#
# Activated by `core.excludesfile = ~/.gitignore_global` in ~/.gitconfig.

# --- Linux ---
*~
.directory
.Trash-*

# --- Editor / IDE swap & workspace files ---
*.swp
*.swo
*.sw[a-p]
.netrwhist
*.sublime-workspace
*.code-workspace
.idea/

# --- Local environment & secrets (belt-and-braces; prefer per-repo too) ---
.env.local
*.pem

# --- Personal tool caches ---
.mypy_cache/
.ruff_cache/
.pytest_cache/
